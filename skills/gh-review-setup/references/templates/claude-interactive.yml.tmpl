# Rendered by Dev10x:gh-review-setup. On-demand @claude review/assistant.
# Optional add-on. Responds only when a comment mentions @claude.
name: Claude Interactive

on:
  issue_comment:
    types: [created]
  pull_request_review_comment:
    types: [created]

permissions:
  contents: read
  pull-requests: write
  issues: write

jobs:
  respond:
    if: contains(github.event.comment.body, '@claude')
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Respond to @claude mention
        uses: {{ACTION_REF}}
        with:
          anthropic_api_key: ${{ secrets.{{REVIEW_KEY}} }}
          claude_args: "--model {{MODEL_CLASSIFY}}"
          prompt: |
            A user mentioned @claude in a comment on ${{ github.repository }}.
            Read the comment and the surrounding PR/issue context and respond
            helpfully and concisely.

            For review requests, load `.claude/rules/INDEX.md`,
            `references/rules/review-guidelines.md`, and
            `references/rules/review-checks-common.md` on demand and apply
            them. Answer the specific question asked — do not run a full
            review unless explicitly asked to.
